# Wildlife Watcher V2 — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values for your target environment.
#
# ENVIRONMENTS:
#   Dev:     Supabase qegeovogqxiouqbrxmnh  |  Azure ww-backend-dev
#   Staging: Supabase nuhwmubvygxyddkycmpa  |  Azure ww-backend
#
# SECURITY: .env is gitignored. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────
# Dev:     https://qegeovogqxiouqbrxmnh.supabase.co
# Staging: https://nuhwmubvygxyddkycmpa.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Security ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=60

# ── LoRaWAN Webhooks ─────────────────────────────────────────────────
LORAWAN_WEBHOOK_SECRET=
LORAWAN_TTN_WEBHOOK_SECRET=
LORAWAN_CHIRPSTACK_WEBHOOK_SECRET=

# ── Azure Storage (Temporary Image Buffer) ───────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
# Dev: wildlife-watcher-uploads-dev  |  Staging: wildlife-watcher-uploads
AZURE_STORAGE_CONTAINER_NAME=wildlife-watcher-uploads-dev

# ── Google Drive (Async Upload) ──────────────────────────────────────
GOOGLE_DRIVE_ENABLED=false
# Dev: 1-F6cQc5lpYOJNSPKRs7i79Gh539N5hUT
# Staging: 1jIWV3OjSEnBK4Z64syHd2ugoRuXdVrK5
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_MAX_FILE_SIZE_MB=50

# ── General ──────────────────────────────────────────────────────────
GENERAL_ORG_ID=b0000000-0000-0000-0000-000000000001
UPLOADER_EMAIL=apps@wildlife.ai
UPLOADER_PASSWORD=test123

# ── Feature Flags ────────────────────────────────────────────────────
FF_INAT_ENABLED=false
FF_ML_ENABLED=false
FF_CLUSTERING_ENABLED=false
FF_LORAWAN_WEBHOOKS_ENABLED=true
FF_PUBLIC_API_ENABLED=false

# ── Observability ────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── Redis (future — not yet required) ────────────────────────────────
REDIS_URL=

# ── iNaturalist (Phase 6 — not yet implemented) ─────────────────────
INAT_CLIENT_ID=
INAT_CLIENT_SECRET=
INAT_REDIRECT_URI=

# ── Public API (behind feature flag) ────────────────────────────────
PUBLIC_API_ENABLED=false
API_KEY_HASH_ROUNDS=12

# ── Frontend (Vite injects at build time) ────────────────────────────
# vite.config.ts auto-maps SUPABASE_URL → VITE_SUPABASE_URL
# Only VITE_API_BASE_URL needs explicit VITE_ prefix.
# Dev:     http://localhost:8000 or https://ww-backend-dev.salmonsand-b067677e.australiasoutheast.azurecontainerapps.io
# Staging: https://ww-backend.salmonsand-b067677e.australiasoutheast.azurecontainerapps.io
VITE_API_BASE_URL=http://localhost:8000
